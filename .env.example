# OKF Vault configuration
#
# Precedence: CLI flags > OKFVAULT_* env vars > config file > defaults
# All keys require the OKFVAULT_ prefix.
#
# Copy to .env and adjust.

OKFVAULT_DATABASE_URL=postgres://okfvault:okfvault@localhost:5432/okf_vault
OKFVAULT_HOST=0.0.0.0
OKFVAULT_PORT=3000
OKFVAULT_LOG_LEVEL=info
OKFVAULT_LOG_PRETTY=false
OKFVAULT_CORS_ORIGINS=
OKFVAULT_API_KEY=
OKFVAULT_MAX_BODY_SIZE=1048576
OKFVAULT_RATE_LIMIT_RPS=100
OKFVAULT_MCP_TRANSPORT=both

# Test database (required for integration tests — no fallback to DATABASE_URL)
# OKFVAULT_DATABASE_TEST_URL=postgres://okfvault:okfvault@localhost:5432/okf_vault_test

# Filesystem bundle mirror (disabled by default)
# OKFVAULT_BUNDLE_STORAGE_ENABLED=true
# OKFVAULT_BUNDLE_STORAGE_PATH=/data/okf-vault
